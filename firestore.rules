rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Requests : création publique (formulaire contact), lecture par le demandeur ou admin
    match /requests/{requestId} {
      allow create: if true;
      allow read: if request.auth != null && (
        request.auth.token.email == resource.data.email ||
        request.auth.token.email == 'brice.faradji@gmail.com'
      );
      allow update, delete: if request.auth != null &&
        request.auth.token.email == 'brice.faradji@gmail.com';
    }

    // Professionals : création pour utilisateurs connectés, lecture publique des approuvés
    match /professionals/{profId} {
      allow create: if request.auth != null;
      allow read: if true;
      allow update: if request.auth != null && (
        request.auth.token.email == resource.data.email ||
        request.auth.token.email == 'brice.faradji@gmail.com'
      );
      allow delete: if request.auth != null &&
        request.auth.token.email == 'brice.faradji@gmail.com';
    }

    // Invoices : pro concerné ou admin
    match /invoices/{invoiceId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        request.auth.token.email == resource.data.proEmail ||
        request.auth.token.email == 'brice.faradji@gmail.com'
      );
      allow update, delete: if request.auth != null &&
        request.auth.token.email == 'brice.faradji@gmail.com';
    }

    // Reviews : création publique, lecture des approuvés, admin gère tout
    match /reviews/{reviewId} {
      allow create: if true;
      allow read: if resource.data.approved == true ||
        (request.auth != null && request.auth.token.email == 'brice.faradji@gmail.com');
      allow update, delete: if request.auth != null &&
        request.auth.token.email == 'brice.faradji@gmail.com';
    }
  }
}
