rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Requests : création publique (formulaire contact), lecture par le demandeur ou admin
    match /requests/{requestId} {
      allow create: if true;
      allow read: if request.auth != null && (
        request.auth.token.email == resource.data.email ||
        request.auth.token.email == 'brice.faradji@gmail.com'
      );
      allow update, delete: if request.auth != null &&
        request.auth.token.email == 'brice.faradji@gmail.com';
    }

    // Professionals : création publique (inscription sans compte), lecture publique des approuvés
    match /professionals/{profId} {
      allow create: if true;
      allow read: if true;
      allow update: if request.auth != null && (
        request.auth.token.email == resource.data.email ||
        request.auth.token.email == 'brice.faradji@gmail.com'
      );
      allow delete: if request.auth != null &&
        request.auth.token.email == 'brice.faradji@gmail.com';
    }

    // Invoices : pro concerné ou admin
    match /invoices/{invoiceId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        request.auth.token.email == resource.data.proEmail ||
        request.auth.token.email == resource.data.clientEmail ||
        request.auth.token.email == 'brice.faradji@gmail.com'
      );
      allow update: if request.auth != null && (
        request.auth.token.email == resource.data.proEmail ||
        request.auth.token.email == 'brice.faradji@gmail.com'
      );
      allow delete: if request.auth != null &&
        request.auth.token.email == 'brice.faradji@gmail.com';
    }

    // Bookings : créés/mis à jour par les routes API serveur (sans auth utilisateur)
    match /bookings/{bookingId} {
      allow create: if true;
      allow read: if request.auth != null && (
        request.auth.token.email == resource.data.proEmail ||
        request.auth.token.email == resource.data.clientEmail ||
        request.auth.token.email == 'brice.faradji@gmail.com'
      );
      allow update: if true;
      allow delete: if request.auth != null &&
        request.auth.token.email == 'brice.faradji@gmail.com';
    }

    // Reviews : création publique, lecture des approuvés, admin gère tout
    match /reviews/{reviewId} {
      allow create: if true;
      allow read: if resource.data.approved == true ||
        (request.auth != null && request.auth.token.email == 'brice.faradji@gmail.com');
      allow update, delete: if request.auth != null &&
        request.auth.token.email == 'brice.faradji@gmail.com';
    }

    // Counters : numérotation des factures (lecture/écriture authentifié)
    match /counters/{counterId} {
      allow read, write: if request.auth != null;
    }

    // Notifications : chaque utilisateur lit/écrit ses propres notifications
    match /notifications/{notifId} {
      allow create: if true;
      allow read, update: if request.auth != null &&
        request.auth.token.email == resource.data.userId;
      allow delete: if request.auth != null && (
        request.auth.token.email == resource.data.userId ||
        request.auth.token.email == 'brice.faradji@gmail.com'
      );
    }

    // Conversations : participants peuvent lire et mettre à jour
    match /conversations/{convoId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (
        request.auth.token.email == resource.data.proEmail ||
        request.auth.token.email == resource.data.clientEmail ||
        request.auth.token.email == 'brice.faradji@gmail.com'
      );
      allow delete: if request.auth != null &&
        request.auth.token.email == 'brice.faradji@gmail.com';

      // Messages : sous-collection de la conversation
      match /messages/{messageId} {
        allow create: if request.auth != null;
        allow read: if request.auth != null && (
          request.auth.token.email == get(/databases/$(database)/documents/conversations/$(convoId)).data.proEmail ||
          request.auth.token.email == get(/databases/$(database)/documents/conversations/$(convoId)).data.clientEmail ||
          request.auth.token.email == 'brice.faradji@gmail.com'
        );
        allow update, delete: if request.auth != null &&
          request.auth.token.email == 'brice.faradji@gmail.com';
      }
    }

  }
}
